# ════════════════════════════════════════════════
# BAUCUA CASINO - Environment Variables
# Copy to .env and fill in your values
# ════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────
NODE_ENV=production
PORT=4000
API_URL=https://baucua-api.onrender.com
WEB_URL=https://baucua.vercel.app
ADMIN_URL=https://baucua-admin.vercel.app

# ─── MongoDB ──────────────────────────────────────
# Get from: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/baucua?retryWrites=true&w=majority

# ─── Redis ───────────────────────────────────────
# Get from: https://upstash.com (free tier) or Redis Cloud
REDIS_URL=redis://default:<password>@<host>:<port>

# ─── Session ─────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your_very_long_random_secret_here_change_this

# ─── GitHub OAuth ─────────────────────────────────
# Create at: https://github.com/settings/applications/new
# Authorization callback: https://baucua-api.onrender.com/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ─── SePay ───────────────────────────────────────
# Đăng ký tại: https://sepay.vn
SEPAY_SECRET=your_sepay_webhook_secret
SEPAY_BANK_CODE=MB
SEPAY_ACCOUNT_NUMBER=your_bank_account_number
SEPAY_ACCOUNT_NAME=TEN TAI KHOAN CUA BAN

# ─── Logging ─────────────────────────────────────
LOG_LEVEL=info
