{
  "version": 2,
  "name": "baucua-admin",
  "framework": "nextjs",
  "installCommand": "yarn install",
  "buildCommand": "yarn workspace @baucua/admin build",
  "outputDirectory": "apps/admin/.next",
  "env": {
    "NEXT_PUBLIC_API_URL": "@baucua-api-url"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
